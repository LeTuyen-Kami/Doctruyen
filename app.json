{
  "expo": {
    "name": "Doctruyen",
    "slug": "Doctruyen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doctruyen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.letuyen1277.Doctruyenchu1",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "processing",
          "fetch"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.letuyen1277.Doctruyenchu.background-timer"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-audio",
      [
        "expo-media-control",
        {
          "audioSessionCategory": "playback"
        }
      ],
      [
        "@revopush/expo-code-push-plugin",
        {
          "ios": {
            "CodePushDeploymentKey": "qlbGBdfxWEQF45Cjix8g5-Z-pG7eEJ_1MOcMXl",
            "CodePushServerUrl": "https://api.revopush.org"
          },
          "android": {
            "CodePushDeploymentKey": "qlbGBdfxWEQF45Cjix8g5-Z-pG7eEJ_1MOcMXl",
            "CodePushServerUrl": "https://api.revopush.org"
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
